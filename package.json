    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "firebase-tools": "^13.35.1",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.49",
