    "firebase-admin": "^13.0.0",
    "next": "^15.1.0",
    "playwright": "^1.59.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.4",
    "server-only": "^0.0.1",
    "zod": "^3.24.0"
