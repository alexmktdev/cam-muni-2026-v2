# Copia este archivo a .env.local y rellena los valores (nunca subas .env.local al repositorio).

# ─── FIREBASE CLIENTE (visibles en el navegador) ─────────────────────────────
# Firebase Console → Configuración del proyecto → Tus apps → SDK de configuración (ícono web)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# Recomendado (mismo snippet): reducen errores auth/invalid-credential si faltan
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# ─── FIREBASE ADMIN (privadas, NUNCA con prefijo NEXT_PUBLIC_) ────────────────
# Cuenta de servicio: Console → Configuración → Cuentas de servicio → Generar clave JSON
# FIREBASE_ID_PROYECTO = project_id del JSON
# FIREBASE_CORREO_CLIENTE = client_email del JSON
# FIREBASE_CLAVE_PRIVADA = private_key del JSON (mantén las comillas en .env)
# La FIREBASE_CLAVE_PRIVADA viene con \n literales en el .env
# Al usarla el código hace: proceso.env.FIREBASE_CLAVE_PRIVADA.replace(/\\n/g, '\n')
FIREBASE_ID_PROYECTO=
FIREBASE_CORREO_CLIENTE=
FIREBASE_CLAVE_PRIVADA=

# Opcional (desarrollo): estimación de lecturas Firestore en la terminal por cada .get() del Admin SDK
# FIRESTORE_READ_METER=1
